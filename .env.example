# Copy this file to .env and fill in your values
# Never commit .env to git

# PostgreSQL / pgvector (Docker)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=calamity_rag

# Embedding model (local, no key needed)
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Modal (for fine-tuning phase)
MODAL_TOKEN_ID=your_modal_token_id
MODAL_TOKEN_SECRET=your_modal_token_secret

# ReliefWeb API (if approved)
RELIEFWEB_APPNAME=your_appname_here

# Serverless LLM Endpoint (Groq LPU)
CLOUD_LLM_ENDPOINT="https://api.groq.com/openai/v1"
CLOUD_LLM_API_KEY="your_groq_api_key_here"
CLOUD_LLM_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# Database URL for async / cloud operations
DATABASE_URL=postgresql://user:pass@host:port/dbname

# Ingestion Webhook Security
INGESTION_SECRET_KEY=generate_a_random_secure_string

# Time-Decay and Historical RAG Configurations
MIN_EVENT_YEAR=2000
DECAY_EARTHQUAKE=0.002
DECAY_FLOOD=0.008
DECAY_DEFAULT=0.005
